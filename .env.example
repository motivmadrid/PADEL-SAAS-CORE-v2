# =============================================================================
# PADEL SAAS — Variables de entorno
# =============================================================================
# Copia este archivo como .env y rellena los valores reales.
# Genera los secretos con: bash scripts/generate-secrets.sh
#
# NUNCA comitees .env al repositorio.
# Este archivo (.env.example) SÍ debe estar en git.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------

# Puerto en el que escucha la aplicación NestJS
PORT=3000

# Entorno de ejecución: development | production | test
# Afecta al nivel de log (debug vs info), cookies seguras y formato JSON de Pino
NODE_ENV=development


# -----------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# -----------------------------------------------------------------------------

# Credenciales usadas tanto por docker-compose (servicio postgres) como por
# Prisma a través de DATABASE_URL. Deben ser consistentes entre sí.

# Usuario de la base de datos
POSTGRES_USER="padel"

# Contraseña de la base de datos — OBLIGATORIA, docker-compose falla sin ella.
# Genera un valor seguro con: openssl rand -hex 16
POSTGRES_PASSWORD="REEMPLAZAR_CON_CONTRASENA_SEGURA"

# Nombre de la base de datos
POSTGRES_DB="padel_db"

# Cadena de conexión Prisma.
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB?schema=public
# Local con Homebrew: postgresql://TU_USUARIO@localhost:5432/padel_db?schema=public
# Docker (apuntar a localhost, docker-compose lo sobreescribe a 'postgres'):
DATABASE_URL="postgresql://padel:REEMPLAZAR_CON_CONTRASENA_SEGURA@localhost:5432/padel_db?schema=public"


# -----------------------------------------------------------------------------
# AUTENTICACIÓN (JWT)
# -----------------------------------------------------------------------------

# Secreto para firmar los Access Tokens (vida corta, ~15 min).
# Mínimo 32 bytes aleatorios. Genera con: openssl rand -hex 32
JWT_ACCESS_SECRET="REEMPLAZAR_CON_SECRETO_GENERADO"

# Secreto para firmar los Refresh Tokens (vida larga, ~7 días).
# Debe ser DISTINTO al Access Secret.
# Genera con: openssl rand -hex 32
JWT_REFRESH_SECRET="REEMPLAZAR_CON_SECRETO_GENERADO"


# -----------------------------------------------------------------------------
# STRIPE (Pagos)
# -----------------------------------------------------------------------------

# Clave secreta de la API de Stripe.
# Desarrollo: empieza por sk_test_
# Producción: empieza por sk_live_
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_REEMPLAZAR_CON_CLAVE_DE_STRIPE"

# Secreto para verificar la firma de los webhooks entrantes de Stripe.
# Desarrollo: obtener con `stripe listen --print-secret` (Stripe CLI)
# Producción: obtener en Dashboard → Developers → Webhooks → tu endpoint
# Empieza siempre por whsec_
STRIPE_WEBHOOK_SECRET="whsec_REEMPLAZAR_CON_SECRETO_DE_WEBHOOK"


# -----------------------------------------------------------------------------
# REDIS (Cache, Locks distribuidos, BullMQ)
# -----------------------------------------------------------------------------

# Host del servidor Redis
REDIS_HOST="localhost"

# Puerto del servidor Redis (por defecto 6379)
REDIS_PORT=6379


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# URL del frontend permitida por el servidor.
# En producción, usar el dominio real: https://app.tudominio.com
FRONTEND_URL="http://localhost:3000"


# -----------------------------------------------------------------------------
# OBSERVABILIDAD (Sentry)
# -----------------------------------------------------------------------------

# DSN del proyecto Sentry para captura de errores y APM.
# Dejar vacío para deshabilitar Sentry en local.
# Obtener en: https://sentry.io → Settings → Projects → tu proyecto → Client Keys
SENTRY_DSN=""
